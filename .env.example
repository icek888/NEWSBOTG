# Local environment configuration
# Copy values from .env.example and customize here

# Database (SQLite для локальной разработки, PostgreSQL для продакшена)
DATABASE_URL=sqlite+aiosqlite:///./ai_news.db

# PostgreSQL для Docker/продакшена (раскомментируй для docker-compose)
# DATABASE_URL=postgresql+asyncpg://newsuser:newspass@db:5432/newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=newspass
POSTGRES_DB=newsdb

# Telegram API
API_HASH=your_api_hash_here
API_ID=your_api_id_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here

# Sources
TECHCRUNCH_URL=https://techcrunch.com
THEVERGE_URL=https://www.theverge.com
HIAI_URL=https://t.me/hiaimedia
POINTS_URL=https://t.me/points_ii

# Scheduler
PARSING_INTERVAL=3600
PUBLICATION_INTERVAL=1800

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_RU=anthropic/claude-3-haiku
OPENROUTER_MODEL_EN=anthropic/claude-3-haiku
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TIMEOUT=30
AI_DEFAULT_LANGUAGE=ru

# Review Settings
REVIEW_BATCH_SIZE=1

# Parser Filters
PARSER_MAX_ARTICLES=20
PARSER_MIN_AGE_HOURS=0
PARSER_MAX_AGE_HOURS=168
PARSER_REQUIRE_IMAGE=false
PARSER_BLOCK_KEYWORDS=

# Publish Filters
PUBLISH_DAILY_LIMIT=10
PUBLISH_REQUIRE_AI_DRAFT=true

# Logging
LOG_LEVEL=INFO
DEBUG=false
